  "modes": {
    "chat": {
      "template": ".cursor/modes/chat-mode.mdc",
      "rules": [
        ".cursor/rules/rules.mdc",
        ".cursor/rules/memory.mdc",
        ".cursor/rules/plan.mdc"
      ]
    },
    "write": {
      "template": ".cursor/modes/write-mode.mdc",
